# Copy this file to .env for local development.
# Keep real secrets in .env or deployment environment variables only.

# Final submission/demo mode uses the mock vision service.
USE_MOCK_VISION=true

# Required only when USE_MOCK_VISION is false.
OPENAI_API_KEY=<OPENAI_API_KEY>

# Optional tuning defaults.
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=3.8
OPENAI_IMAGE_DETAIL=low
PREPROCESS_MAX_DIMENSION=768
PREPROCESS_JPEG_QUALITY=75
BATCH_CONCURRENCY=3
