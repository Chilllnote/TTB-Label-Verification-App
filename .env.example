# Environment variables for local development and deployment
# Copy this file to .env and fill in real values locally.

# OpenAI API key for label vision extraction (GPT-4o)
# Get your key from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Use mock vision service instead of real API (for testing)
# Set to "true" to skip API calls and use MockVisionService
USE_MOCK_VISION=false
